{
  "name": "ai-agent-test",
  "version": "0.13.9",
  "main": "dist/index.js",
  "bin": {
    "ai": "./bin/ai"
  },
  "type": "module",
  "files": [
    "dist",
    "bin",
    "*.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepare": "husky",
    "lint": "oxlint . -c .oxlintrc.json --ignore-pattern dist/",
    "dev": "tsx -r dotenv/config src/index.ts",
    "prepack": "rm -rf dist && npm run build"
  },
  "author": "Bright Lee <benevbright@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/benevbright/ai-agent-test.git"
  },
  "license": "ISC",
  "description": "A lightweight agentic workflow system for testing AI agent flows with local LLMs and tool integrations",
  "keywords": [
    "ai",
    "agent",
    "agentic",
    "workflow",
    "llm",
    "local-llm",
    "cli",
    "automation"
  ],
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.60.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai": "^3.0.53",
    "@benevbright/read-multiline": "^0.3.3-beta.1",
    "ai": "^6.0.168",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "jsdom": "^29.0.2",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,css,md}": "prettier --write"
  }
}
