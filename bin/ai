#!/usr/bin/env node

// Load config first (before any imports that use it)
import { loadConfig } from '../dist/config.js';
const config = loadConfig();
process.env.AI_MODEL_APITYPE = config.modelApiType;
process.env.AI_MODEL_NAME = config.modelName;
process.env.AI_API_BASE_URL = config.apiBaseUrl;
process.env.AI_API_KEY = config.apiKey;

// Pass command-line arguments to the main module
import { argv } from 'process';

// Handle --version command
if (argv[2] === '--version') {
  import('fs').then(({ readFileSync }) => {
    const packageJson = JSON.parse(readFileSync(new URL('../package.json', import.meta.url), 'utf-8'));
    console.log(packageJson.version);
    process.exit(0);
  });
}

// Handle --help command
if (argv[2] === '--help') {
  import('fs').then(({ readFileSync }) => {
    const packageJson = JSON.parse(readFileSync(new URL('../package.json', import.meta.url), 'utf-8'));
    console.log(`ai-agent-test v${packageJson.version}

Usage: ai [options] [model-index]

Commands:
  sessions       List last 20 sessions
  update         Update the ai-agent-test package to the latest version
  --version      Show version number
  --help         Show help message

Arguments:
  model-index    Index of the model to use (from ~/.ai/models.json)

Examples:
  ai                    # Run with default model
  ai 1                  # Run with second model in config
  ai sessions           # List last 20 sessions
  ai update             # Update to latest version
  ai --version          # Show version
  ai --help             # Show help
`);
    process.exit(0);
  });
}

// Handle update command
if (argv[2] === 'update') {
  import('child_process').then(({ execSync }) => {
    execSync('npm install -g ai-agent-test', { stdio: 'inherit' });
    process.exit(0);
  });
}

// Handle sessions command
if (argv[2] === 'sessions') {
  import('../dist/utils/system.js').then(({ listSessions }) => {
    const sessions = listSessions(20);
    if (sessions.length === 0) {
      console.log('No sessions found.');
    } else {
      console.log(`Last ${sessions.length} sessions:`);
      sessions.forEach((session, index) => {
        let line = `${index + 1}. ${session.timestamp}`;
        if (session.summary) {
          line += ` - ${session.summary}`;
        }
        console.log(line);
      });
    }
    process.exit(0);
  });
}

// Set AI_MODEL_INDEX environment variable if provided as first argument
if (argv[2]) {
  process.env.AI_MODEL_INDEX = argv[2];
}

import('../dist/index.js');
